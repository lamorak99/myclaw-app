#!/bin/bash
# Start Gerty - launches backend and app together

# Start backend in background
cd ~/Development/cursor-myclaw-core
source .venv/bin/activate
myclaw web &
BACKEND_PID=$!

# Wait for backend to be ready
for i in {1..10}; do
  if curl -s http://127.0.0.1:8000/health >/dev/null 2>&1; then
    break
  fi
  sleep 1
done

# Launch Gerty app
open /Applications/Gerty.app

# Keep backend running until Gerty closes
wait $BACKEND_PID
